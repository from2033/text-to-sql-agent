# Copy to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (defaults shown)
SQL_MODEL=claude-sonnet-4-6
EXPLAIN_MODEL=claude-haiku-4-5-20251001

# Embedding backend: "sentence-transformers" (default, offline) or "anthropic"
EMBEDDING_BACKEND=sentence-transformers
ST_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Storage paths
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/training.db

# Limits
MAX_RESULT_ROWS=500
MAX_QUERY_PREVIEW_ROWS=20
